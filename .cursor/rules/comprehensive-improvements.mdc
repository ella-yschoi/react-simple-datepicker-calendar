## 📈 모니터링 및 분석

### **1. 사용성 분석**
```typescript
// ✅ IMPROVED - 사용성 분석 시스템
interface AnalyticsEvents {
  dateSelected: (date: Date, method: 'click' | 'keyboard' | 'input') => void;
  monthChanged: (from: Date, to: Date) => void;
  errorOccurred: (error: string, context: any) => void;
  featureUsed: (feature: string) => void;
}

const useAnalytics = (): AnalyticsEvents => {
  const trackEvent = useCallback((event: string, data: any) => {
    // Send to analytics service
    if (typeof window !== 'undefined' && window.gtag) {
      window.gtag('event', event, data);
    }
  }, []);

  return {
    dateSelected: (date, method) => {
      trackEvent('calendar_date_selected', { date: date.toISOString(), method });
    },
    monthChanged: (from, to) => {
      trackEvent('calendar_month_changed', { 
        from: from.toISOString(), 
        to: to.toISOString() 
      });
    },
    errorOccurred: (error, context) => {
      trackEvent('calendar_error', { error, context });
    },
    featureUsed: (feature) => {
      trackEvent('calendar_feature_used', { feature });
    }
  };
};
```

### **2. 성능 모니터링**
```typescript
// ✅ IMPROVED - 성능 모니터링
const usePerformanceMonitoring = () => {
  const [metrics, setMetrics] = useState({
    renderTime: 0,
    interactionTime: 0,
    memoryUsage: 0
  });

  const measurePerformance = useCallback((operation: string) => {
    const start = performance.now();
    return () => {
      const duration = performance.now() - start;
      setMetrics(prev => ({ ...prev, [operation]: duration }));
      
      // Alert if performance is poor
      if (duration > 16) {
        console.warn(`${operation} took ${duration}ms (exceeds 16ms threshold)`);
      }
    };
  }, []);

  return { metrics, measurePerformance };
};
```

