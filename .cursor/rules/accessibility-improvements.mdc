# Accessibility Improvements for React DatePicker Calendar

## 🎯 Critical Accessibility Issues to Address

### **1. ARIA Labels & Roles**
```typescript
// ❌ CURRENT - Missing accessibility attributes
const DateUnit: React.FC<DateUnitProps> = ({ onClick, date }) => (
  <StyledDateUnit onClick={onClick}>
    {date}
  </StyledDateUnit>
);

// ✅ IMPROVED - With proper ARIA attributes
const DateUnit: React.FC<DateUnitProps> = ({ onClick, date, isSelected, isToday }) => (
  <StyledDateUnit
    onClick={onClick}
    role="button"
    tabIndex={0}
    aria-label={`Select date ${date}`}
    aria-selected={isSelected}
    aria-current={isToday ? 'date' : undefined}
    onKeyDown={(e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        onClick();
      }
    }}
  >
    {date}
  </StyledDateUnit>
);
```

### **2. Keyboard Navigation**
```typescript
// ✅ IMPROVED - Full keyboard navigation support
const CalendarContainer: React.FC<CalendarProps> = ({ value, onChange }) => {
  const [focusedDate, setFocusedDate] = useState<Date>(value);
  
  const handleKeyDown = useCallback((e: React.KeyboardEvent) => {
    switch (e.key) {
      case 'ArrowLeft':
        e.preventDefault();
        setFocusedDate(prev => new Date(prev.getTime() - 24 * 60 * 60 * 1000));
        break;
      case 'ArrowRight':
        e.preventDefault();
        setFocusedDate(prev => new Date(prev.getTime() + 24 * 60 * 60 * 1000));
        break;
      case 'ArrowUp':
        e.preventDefault();
        setFocusedDate(prev => new Date(prev.getTime() - 7 * 24 * 60 * 60 * 1000));
        break;
      case 'ArrowDown':
        e.preventDefault();
        setFocusedDate(prev => new Date(prev.getTime() + 7 * 24 * 60 * 60 * 1000));
        break;
      case 'Enter':
      case ' ':
        e.preventDefault();
        onChange(focusedDate);
        break;
    }
  }, [onChange]);

  return (
    <div role="grid" aria-label="Calendar" onKeyDown={handleKeyDown}>
      {/* Calendar content */}
    </div>
  );
};
```

### **3. Screen Reader Support**
```typescript
// ✅ IMPROVED - Screen reader announcements
const Calendar: React.FC<CalendarProps> = ({ value, onChange }) => {
  const [announcement, setAnnouncement] = useState('');
  
  const announceDateChange = useCallback((newDate: Date) => {
    const formattedDate = newDate.toLocaleDateString('en-US', {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });
    setAnnouncement(`Selected date: ${formattedDate}`);
  }, []);

  return (
    <>
      <div aria-live="polite" aria-atomic="true" className="sr-only">
        {announcement}
      </div>
      {/* Calendar content */}
    </>
  );
};
```

