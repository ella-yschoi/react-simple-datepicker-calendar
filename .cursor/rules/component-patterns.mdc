## 🔍 Error Handling Patterns

### **Input Validation Pattern:**
```typescript
// ✅ CORRECT - Comprehensive input validation
const validateDateInput = (input: string): boolean => {
  const dateRegex = /^\d{4}\/\d{1,2}\/\d{1,2}$/;
  const isValidFormat = dateRegex.test(input);

  if (!isValidFormat) return false;

  const [yearStr, monthStr, dayStr] = input.split('/');
  const year = parseInt(yearStr, 10);
  const month = parseInt(monthStr, 10);
  const day = parseInt(dayStr, 10);

  const dateObj = new Date(year, month - 1, day);
  const isValidDate =
    dateObj.getFullYear() === year &&
    dateObj.getMonth() === month - 1 &&
    dateObj.getDate() === day;

  return isValidDate;
};
```

## 📚 Documentation Patterns

### **JSDoc Pattern:**
```typescript
/**
 * Calendar component for date selection with customizable styling
 * 
 * @param {string} [calendarBackgroundColor] - Background color of the entire calendar component
 * @param {string} [displayBackgroundColor] - Background color for the display area
 * @param {string} [displayFontColor] - Font color for the display area
 * @param {string} [dayFontColor] - Font color for the day names
 * @param {string} [currentDateFontColor] - Font color for the current date
 * @param {string} [prevNextDateFontColor] - Font color for previous/next month dates
 * @param {'en'|'ko'} [language] - Language settings for the calendar
 * @param {Date} value - The currently selected date
 * @param {function} onChange - Function to call when the date is changed
 * 
 * @example
 * ```tsx
 * <Calendar
 *   value={selectedDate}
 *   onChange={handleDateChange}
 *   language="ko"
 *   calendarBackgroundColor="#333"
 * />
 * ```
 */
```

