// ✅ CORRECT - Memoized component with stable props
const MemoizedDateUnit = React.memo<DateUnitProps>(({
  className,
  onClick,
  date,
  $currentDateFontColor,
  $prevNextDateFontColor
}) => {
  const handleClick = useCallback(() => {
    onClick();
