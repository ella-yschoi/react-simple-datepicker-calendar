## 🎯 Grid Component Patterns

### **Date Grid Pattern:**
Reference: [src/components/grids/DateGrid.tsx](mdc:src/components/grids/DateGrid.tsx)

```typescript
// ✅ CORRECT - Grid with conditional rendering
interface DateGridProps {
  prevMonthDays: number[];
  currentMonthDays: number[];
  nextMonthDays: number[];
  isToday: (date: Date) => boolean;
  isSelected: (date: Date) => boolean;
  handleDateSelect: (year: number, month: number, day: number) => void;
  currentDate: Date;
  selectedDate: Date;
  $currentDateFontColor?: string;
  $prevNextDateFontColor?: string;
}

const DateGrid: React.FC<DateGridProps> = ({
  prevMonthDays,
  currentMonthDays,
  nextMonthDays,
  isToday,
  isSelected,
  handleDateSelect,
  currentDate,
  selectedDate,
  $currentDateFontColor,
  $prevNextDateFontColor,
}) => {
  const renderDateUnit = useCallback((day: number, type: 'prev' | 'current' | 'next') => {
    const date = new Date(currentDate.getFullYear(), currentDate.getMonth(), day);
    const isTodayDate = isToday(date);
    const isSelectedDate = isSelected(date);
    
    const className = [
      isTodayDate ? 'today' : '',
      isSelectedDate ? 'selected' : ''
    ].filter(Boolean).join(' ');

    return (
      <DateUnit
        key={`${type}-${day}`}
        className={className}
        date={day}
        onClick={() => handleDateSelect(date.getFullYear(), date.getMonth() + 1, day)}
        $currentDateFontColor={$currentDateFontColor}
        $prevNextDateFontColor={$prevNextDateFontColor}
      />
    );
  }, [currentDate, isToday, isSelected, handleDateSelect, $currentDateFontColor, $prevNextDateFontColor]);

  return (
    <StyledDateGrid>
      {prevMonthDays.map(day => renderDateUnit(day, 'prev'))}
      {currentMonthDays.map(day => renderDateUnit(day, 'current'))}
      {nextMonthDays.map(day => renderDateUnit(day, 'next'))}
    </StyledDateGrid>
  );
};
```

## 🚀 Performance Patterns

### **Memoization Pattern:**
