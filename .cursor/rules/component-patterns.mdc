  return (
    <StyledDateUnit
      className={className}
      onClick={handleClick}
      date={date}
      $currentDateFontColor={$currentDateFontColor}
      $prevNextDateFontColor={$prevNextDateFontColor}
    >
      {date}
    </StyledDateUnit>
  );
});
```

