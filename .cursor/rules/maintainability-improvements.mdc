## 🔧 Error Handling & Validation

### **1. Comprehensive Error Handling**
```typescript
// ✅ IMPROVED - Error handling system
class CalendarError extends Error {
  constructor(
    message: string,
    public code: string,
    public context?: any
  ) {
    super(message);
    this.name = 'CalendarError';
  }
}

const ErrorCodes = {
  INVALID_DATE: 'INVALID_DATE',
  OUT_OF_RANGE: 'OUT_OF_RANGE',
  INVALID_FORMAT: 'INVALID_FORMAT',
  LOCALE_NOT_FOUND: 'LOCALE_NOT_FOUND',
  THEME_NOT_FOUND: 'THEME_NOT_FOUND'
} as const;

// Error handling hook
const useErrorHandler = () => {
  const [errors, setErrors] = useState<CalendarError[]>([]);
  
  const handleError = useCallback((error: CalendarError) => {
    setErrors(prev => [...prev, error]);
    
    // Log error for debugging
    console.error(`Calendar Error [${error.code}]:`, error.message, error.context);
    
    // Send to error tracking service
    if (process.env.NODE_ENV === 'production') {
      // Send to Sentry, LogRocket, etc.
    }
  }, []);
  
  const clearErrors = useCallback(() => {
    setErrors([]);
  }, []);
  
  return { errors, handleError, clearErrors };
};
```

### **2. Input Validation System**
```typescript
// ✅ IMPROVED - Comprehensive validation
interface ValidationResult {
  isValid: boolean;
  errors: string[];
  warnings: string[];
}

const validateDateInput = (input: string, format: string): ValidationResult => {
  const errors: string[] = [];
  const warnings: string[] = [];
  
  // Format validation
  const formatRegex = /^\d{4}\/\d{1,2}\/\d{1,2}$/;
  if (!formatRegex.test(input)) {
    errors.push('Date format must be YYYY/MM/DD');
    return { isValid: false, errors, warnings };
  }
  
  // Parse date
  const [yearStr, monthStr, dayStr] = input.split('/');
  const year = parseInt(yearStr, 10);
  const month = parseInt(monthStr, 10);
  const day = parseInt(dayStr, 10);
  
  // Range validation
  if (year < 1900 || year > 2100) {
    errors.push('Year must be between 1900 and 2100');
  }
  
  if (month < 1 || month > 12) {
    errors.push('Month must be between 1 and 12');
  }
  
  if (day < 1 || day > 31) {
    errors.push('Day must be between 1 and 31');
  }
  
  // Date existence validation
  const dateObj = new Date(year, month - 1, day);
  const isValidDate = 
    dateObj.getFullYear() === year &&
    dateObj.getMonth() === month - 1 &&
    dateObj.getDate() === day;
    
  if (!isValidDate) {
    errors.push('Invalid date');
  }
  
  // Warnings
  if (year < 2000 || year > 2030) {
    warnings.push('Date is outside recommended range');
  }
  
  return {
    isValid: errors.length === 0,
    errors,
    warnings
  };
};
```

## 🧪 Testing Strategy

### **1. Comprehensive Test Structure**
```typescript
// ✅ IMPROVED - Test organization
describe('Calendar Component', () => {
  describe('Rendering', () => {
    it('should render with default props', () => {
      render(<Calendar value={new Date()} onChange={jest.fn()} />);
      expect(screen.getByRole('grid')).toBeInTheDocument();
    });
    
    it('should render with custom theme', () => {
      const customTheme = { colors: { primary: '#ff0000' } };
      render(
        <Calendar 
          value={new Date()} 
          onChange={jest.fn()} 
          theme={customTheme}
        />
      );
      // Assert theme is applied
    });
  });
  
  describe('Date Selection', () => {
    it('should call onChange when date is selected', () => {
      const onChange = jest.fn();
      render(<Calendar value={new Date()} onChange={onChange} />);
      
      const dateButton = screen.getByRole('button', { name: /select date 15/i });
      fireEvent.click(dateButton);
      
      expect(onChange).toHaveBeenCalledWith(expect.any(Date));
    });
    
    it('should not call onChange for disabled dates', () => {
      const onChange = jest.fn();
      const disabledDate = new Date(2024, 0, 15);
      
      render(
        <Calendar 
          value={new Date()} 
          onChange={onChange}
          disabledDates={[disabledDate]}
        />
      );
      
      const disabledButton = screen.getByRole('button', { name: /select date 15/i });
      expect(disabledButton).toBeDisabled();
      
      fireEvent.click(disabledButton);
      expect(onChange).not.toHaveBeenCalled();
    });
  });
  
  describe('Keyboard Navigation', () => {
    it('should navigate with arrow keys', () => {
      render(<Calendar value={new Date()} onChange={jest.fn()} />);
      
      const calendar = screen.getByRole('grid');
      fireEvent.keyDown(calendar, { key: 'ArrowRight' });
      
      // Assert focus moved to next date
    });
  });
  
  describe('Accessibility', () => {
    it('should have no accessibility violations', async () => {
      const { container } = render(
        <Calendar value={new Date()} onChange={jest.fn()} />
      );
      const results = await axe(container);
      expect(results).toHaveNoViolations();
    });
  });
});
