```typescript
// ✅ IMPROVED - Centralized state with context
interface CalendarState {
  // Current view state
  currentDate: Date;
  selectedDate: Date | null;
  selectedRange: { start: Date; end: Date } | null;
  viewMode: CalendarView;
  
